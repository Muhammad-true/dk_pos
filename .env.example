# Шаблон: скопируйте в assets/.env (или отредактируйте assets/.env в проекте).
# Android-эмулятор: http://10.0.2.2:3000
# Указывайте только хост и порт (без /api) — к api/ пути добавляются в коде.
API_BASE_URL=http://192.168.1.108:3000
# --- Лицензия (глобальный API, без /api в конце URL) ---
# Если на локальном backend задан GLOBAL_LICENSE_API_BASE_URL, POS сначала ходит на
# GET/POST …/api/local/license/* (снимок в MySQL на сервере). Иначе — прямой глобальный API:
# GLOBAL_LICENSE_API_BASE_URL=https://api.donerkebab.tj
# GLOBAL_LICENSE_API_BASE_URL=

# --- Релизы POS (глобальный API, без /api) ---
# Если заданы обе строки, при запуске касса запрашивает GET …/api/v1/releases/check (канал stable, компонент pos_windows / pos_android).
# GLOBAL_UPDATE_CLIENT_TOKEN должен совпадать с UPDATE_CLIENT_TOKEN в .env глобального API (docker dk_global или api.donerkebab.tj/.env).
# GLOBAL_RELEASES_BASE_URL=https://api.donerkebab.tj
# GLOBAL_UPDATE_CLIENT_TOKEN=
# Второе окно «экран клиента». Если касса вылетает с двумя мониторами: true и заново flutter build windows (в установщик попадает assets/.env из сборки).
# POS_DISABLE_CUSTOMER_DISPLAY=true
# Разгрузка кассы (опционально):
# POS_CASHIER_REFRESH_INTERVAL_SEC=35
# POS_CASHIER_REALTIME_MIN_GAP_MS=2500
# POS_EXPEDITOR_REFRESH_INTERVAL_SEC=30
HARDWARE_MODE=mock
CASH_DRAWER_ALLOWED_TERMINALS=KASSA-1
# branch_id в runtime берется из franchise id локальной лицензии.
POS_TERMINAL_ID=KASSA-1
TV_FAKE_DELIVERY_ENABLED=true
